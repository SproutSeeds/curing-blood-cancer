{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/mechanism-extraction.schema.json",
  "title": "Curing Blood Cancer Mechanism Extraction",
  "type": "object",
  "required": [
    "extraction_record_id",
    "date",
    "disease_program",
    "parent_map_id",
    "source_ids",
    "mechanism_group_ids",
    "clinical_use_boundary",
    "source_record",
    "extracted_signals",
    "evidence_boundary",
    "review"
  ],
  "properties": {
    "extraction_record_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "parent_map_id": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "taxonomy_class_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism_group_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_record": {
      "type": "object",
      "required": [
        "source_type",
        "title",
        "url",
        "accessed",
        "publication_year",
        "study_context"
      ],
      "properties": {
        "source_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string"
        },
        "pmid": {
          "type": "string"
        },
        "accessed": {
          "type": "string",
          "format": "date"
        },
        "publication_year": {
          "type": "integer"
        },
        "study_context": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "extracted_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "signal_id",
          "mechanism_group_id",
          "signal_summary",
          "evidence_level",
          "direction",
          "measurement_fields",
          "limitations"
        ],
        "properties": {
          "signal_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "mechanism_group_id": {
            "type": "string"
          },
          "signal_summary": {
            "type": "string"
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "source-summary",
              "registry-record",
              "regulatory-record",
              "observational-study",
              "clinical-trial",
              "systematic-review",
              "mechanistic-preclinical",
              "expert-review-needed",
              "hypothesis-only"
            ]
          },
          "direction": {
            "type": "string",
            "enum": [
              "supports",
              "contradicts",
              "mixed",
              "unclear",
              "not-assessed"
            ]
          },
          "measurement_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "denominator_context": {
            "type": "object",
            "required": [
              "population_denominator",
              "numerator_observed",
              "denominator_basis",
              "cohort_context",
              "product_or_class_context",
              "prior_bcma_exposure_context",
              "assay_method",
              "specimen_source",
              "target_assay_timing",
              "relapse_or_response_state",
              "frequency_claim_support",
              "frequency_claim_boundary"
            ],
            "properties": {
              "population_denominator": {
                "type": "integer"
              },
              "numerator_observed": {
                "type": "integer"
              },
              "denominator_basis": {
                "type": "string"
              },
              "cohort_context": {
                "type": "string"
              },
              "product_or_class_context": {
                "type": "string"
              },
              "prior_bcma_exposure_context": {
                "type": "string"
              },
              "assay_method": {
                "type": "string"
              },
              "specimen_source": {
                "type": "string"
              },
              "target_assay_timing": {
                "type": "string"
              },
              "relapse_or_response_state": {
                "type": "string"
              },
              "paired_measurement_context": {
                "type": "string"
              },
              "frequency_claim_support": {
                "type": "string",
                "enum": [
                  "source-cohort-count-only",
                  "insufficient-denominator",
                  "not-applicable"
                ]
              },
              "frequency_claim_boundary": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "translation_safety_context": {
            "type": "object",
            "required": [
              "evidence_domain",
              "tumor_target_context",
              "normal_tissue_context",
              "model_context",
              "clinical_translation_status",
              "trial_registry_context",
              "efficacy_claim_boundary",
              "safety_claim_boundary"
            ],
            "properties": {
              "evidence_domain": {
                "type": "string",
                "enum": [
                  "target-biology",
                  "preclinical-activity",
                  "normal-tissue-safety",
                  "clinical-translation",
                  "trial-registry-context"
                ]
              },
              "tumor_target_context": {
                "type": "string"
              },
              "normal_tissue_context": {
                "type": "string"
              },
              "model_context": {
                "type": "string"
              },
              "clinical_translation_status": {
                "type": "string"
              },
              "trial_registry_context": {
                "type": "string"
              },
              "efficacy_claim_boundary": {
                "type": "string"
              },
              "safety_claim_boundary": {
                "type": "string"
              },
              "actionability_boundary": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_boundary": {
      "type": "object",
      "required": ["what_this_supports", "what_this_does_not_support"],
      "properties": {
        "what_this_supports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "what_this_does_not_support": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/mechanism-extraction.schema.json",
  "title": "Curing Blood Cancer Mechanism Extraction",
  "type": "object",
  "required": [
    "extraction_record_id",
    "date",
    "disease_program",
    "parent_map_id",
    "source_ids",
    "mechanism_group_ids",
    "clinical_use_boundary",
    "source_record",
    "extracted_signals",
    "evidence_boundary",
    "review"
  ],
  "properties": {
    "extraction_record_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "parent_map_id": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "taxonomy_class_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism_group_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_record": {
      "type": "object",
      "required": [
        "source_type",
        "title",
        "url",
        "accessed",
        "publication_year",
        "study_context"
      ],
      "properties": {
        "source_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string"
        },
        "pmid": {
          "type": "string"
        },
        "accessed": {
          "type": "string",
          "format": "date"
        },
        "publication_year": {
          "type": "integer"
        },
        "study_context": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "extracted_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "signal_id",
          "mechanism_group_id",
          "signal_summary",
          "evidence_level",
          "direction",
          "measurement_fields",
          "limitations"
        ],
        "properties": {
          "signal_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "mechanism_group_id": {
            "type": "string"
          },
          "signal_summary": {
            "type": "string"
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "source-summary",
              "registry-record",
              "regulatory-record",
              "observational-study",
              "clinical-trial",
              "systematic-review",
              "mechanistic-preclinical",
              "expert-review-needed",
              "hypothesis-only"
            ]
          },
          "direction": {
            "type": "string",
            "enum": [
              "supports",
              "contradicts",
              "mixed",
              "unclear",
              "not-assessed"
            ]
          },
          "measurement_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_boundary": {
      "type": "object",
      "required": ["what_this_supports", "what_this_does_not_support"],
      "properties": {
        "what_this_supports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "what_this_does_not_support": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}


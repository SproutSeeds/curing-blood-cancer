              "cell-surface-antigen",
              "gene-or-protein",
              "pathway",
              "immune-context",
              "microenvironment-context",
              "other-public-target-record"
            ]
          },
          "claim_level": {
            "type": "string",
            "enum": ["derived", "hypothesis", "open-question", "do-not-use-clinically"]

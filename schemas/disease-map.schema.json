              "approved-class",
              "investigational-class",
              "procedure-or-modality",
              "supportive-context",
              "research-only-class",
              "other-public-therapy-record"
            ]
          },
          "claim_level": {
            "type": "string",
            "enum": ["derived", "hypothesis", "open-question", "do-not-use-clinically"]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_gap_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "clinical_use_boundary": {
            "type": "string",
            "enum": [
              "not-medical-advice",
              "not-treatment-recommendation",
              "not-trial-recommendation",
              "research-use-only"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "trial_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "trial_record_id",
          "label",
          "trial_record_type",
          "claim_level",
          "registry_source_ids",
          "trial_query_record_ids",
          "uncertainty",
          "limitations",
          "clinical_use_boundary"
        ],
        "properties": {
          "trial_record_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "trial_record_type": {
            "type": "string",
            "enum": [
              "registry-landscape",
              "query-protocol",
              "aggregate-counts",
              "eligibility-boundary",
              "other-public-trial-record"
            ]
          },
          "claim_level": {
            "type": "string",
            "enum": ["derived", "hypothesis", "open-question", "do-not-use-clinically"]
          },
          "registry_source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "trial_query_record_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "clinical_use_boundary": {
            "type": "string",
            "enum": [
              "not-medical-advice",
              "not-treatment-recommendation",
              "not-trial-recommendation",
              "research-use-only"
            ]
          }

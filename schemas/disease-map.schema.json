          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_gap_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "clinical_use_boundary": {
            "type": "string",
            "enum": [
              "not-medical-advice",
              "not-diagnostic",
              "not-treatment-recommendation",
              "not-trial-recommendation",
              "research-use-only"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "therapy_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "therapy_id",
          "label",
          "therapy_record_type",
          "claim_level",
          "source_ids",
          "linked_claim_ids",
          "linked_gap_ids",
          "uncertainty",
          "limitations",
          "clinical_use_boundary"
        ],
        "properties": {
          "therapy_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "therapy_record_type": {
            "type": "string",

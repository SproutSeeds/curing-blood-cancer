{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/disease-map.schema.json",
  "title": "Curing Blood Cancer Disease Map",
  "type": "object",
  "required": [
    "disease_map_id",
    "date",
    "title",
    "disease_program",
    "disease_scope",
    "claim_level",
    "clinical_use_boundary",
    "source_ids",
    "uncertainty",
    "limitations",
    "facts",
    "derived_claims",
    "hypotheses",
    "open_questions",
    "target_records",
    "therapy_records",
    "trial_records",
    "linked_gap_ids",
    "public_task_ids",
    "review"
  ],
  "properties": {
    "disease_map_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+(?:-[0-9]+)?$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "disease_program": {
      "type": "string",
      "minLength": 1
    },
    "disease_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claim_level": {
      "type": "string",
      "enum": ["fact", "derived", "hypothesis", "open-question", "do-not-use-clinically"]
    },
    "clinical_use_boundary": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "not-medical-advice",
          "not-diagnostic",
          "not-treatment-recommendation",
          "not-trial-recommendation",
          "not-expanded-access-guidance",
          "not-patient-specific",
          "research-use-only",
          "requires-human-review"
        ]
      },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "uncertainty": {
      "type": "object",
      "required": ["summary", "review_status", "known_unknowns"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "blocked"
          ]
        },
        "known_unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact_id", "statement", "scope", "source_ids", "uncertainty", "limitations"],
        "properties": {
          "fact_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "derived_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "statement",
          "claim_level",
          "source_ids",
          "linked_claim_ids",
          "uncertainty",
          "limitations"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "claim_level": {
            "type": "string",
            "enum": ["derived", "open-question", "do-not-use-clinically"]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hypothesis_id", "statement", "claim_level", "source_ids", "uncertainty", "limitations"],
        "properties": {
          "hypothesis_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "claim_level": {
            "type": "string",
            "enum": ["hypothesis", "open-question", "do-not-use-clinically"]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "question",
          "question_type",
          "source_ids",
          "linked_gap_ids",
          "public_task_ids",
          "uncertainty",
          "limitations"
        ],
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "question_type": {
            "type": "string",
            "enum": [
              "target",
              "therapy",
              "trial",
              "measurement",
              "mechanism",
              "review",
              "source-coverage",
              "schema-tooling"
            ]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_gap_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "public_task_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "target_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "label",
          "target_record_type",
          "claim_level",
          "source_ids",
          "linked_claim_ids",
          "linked_gap_ids",
          "uncertainty",
          "limitations",
          "clinical_use_boundary"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "target_record_type": {
            "type": "string",

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/review-packet-route-table-output.schema.json",
  "title": "Curing Blood Cancer Review-Packet Route-Table Output",
  "type": "object",
  "required": [
    "route_table_id",
    "input_manifest_id",
    "tool",
    "route_table_status",
    "output_boundary",
    "copied_reference_routes",
    "missing_input_records",
    "refusal_records",
    "validation_checks",
    "do_not_infer"
  ],
  "properties": {
    "route_table_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "input_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "enum": [
        "tools/review_packet_manifest_route_table.py"
      ]
    },
    "route_table_status": {
      "type": "string",
      "enum": [
        "route-table-ready",
        "route-table-ready-with-missing-inputs",
        "refused"
      ]
    },
    "claim_level": {
      "type": "string",
      "enum": [
        "fact",
        "derived",
        "hypothesis",
        "open-question",
        "do-not-use-clinically"
      ]
    },
    "clinical_use_boundary": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "not-medical-advice",
          "not-diagnostic",
          "not-treatment-recommendation",
          "not-trial-recommendation",
          "research-use-only"
        ]
      },
      "uniqueItems": true
    },
    "output_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "copied_reference_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "route_id",
          "manifest_section",
          "decision",
          "copied_fields",
          "output_boundary"
        ],
        "properties": {
          "route_id": {
            "type": "string",
            "pattern": "^route-[0-9]{3}-[a-z0-9_-]+(?:-[a-z0-9_-]+)*$"
          },
          "manifest_section": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "enum": [
              "copy",
              "reference",
              "omit"
            ]
          },
          "copied_fields": {
            "type": "object"
          },
          "output_boundary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "missing_input_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "missing_input_id",
          "missing_kind",
          "reason_missing",
          "blocking_state",
          "next_public_task_ids"
        ],
        "properties": {
          "missing_input_id": {
            "type": "string",
            "minLength": 1
          },
          "missing_kind": {
            "type": "string",
            "enum": [
              "source",
              "artifact",
              "schema",
              "validator",
              "review",
              "builder-code",
              "publication-gate",
              "other-public-input"
            ]
          },
          "reason_missing": {
            "type": "string",
            "minLength": 1
          },
          "blocking_state": {
            "type": "string",
            "enum": [
              "blocks-builder-code",
              "blocks-generated-output",
              "blocks-publication-use",
              "non-blocking-note"
            ]
          },
          "next_public_task_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "refusal_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "location",
          "reason"
        ],
        "properties": {
          "refusal_kind": {
            "type": "string"
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "field": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check",
          "status"
        ],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "refused"
            ]
          },
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "do_not_infer": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

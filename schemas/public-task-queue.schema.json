{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/public-task-queue.schema.json",
  "title": "Curing Blood Cancer Public Task Queue",
  "type": "object",
  "required": [
    "task_queue_id",
    "date",
    "disease_program",
    "title",
    "blood_cancer_scope",
    "clinical_use_boundary",
    "gap_register_ids",
    "source_ids",
    "tasks",
    "review"
  ],
  "properties": {
    "task_queue_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "gap_register_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "task_title",
          "task_type",
          "priority",
          "status",
          "suggested_issue_form",
          "linked_gap_ids",
          "linked_claim_ids",
          "source_ids",
          "public_deliverables",
          "acceptance_checks",
          "what_not_to_infer",
          "safety_boundary"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "task_title": {
            "type": "string",
            "minLength": 1
          },
          "task_type": {
            "type": "string",
            "enum": [
              "evidence-gap-task",
              "expert-review-task",
              "source-extraction-task",
              "tooling-task"
            ]
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["ready", "blocked", "in-progress", "done", "deferred"]
          },
          "suggested_issue_form": {
            "type": "string",
            "enum": [
              "evidence-gap-task.yml",
              "expert-review-task.yml",
              "source-extraction-task.yml",
              "pull-request-only"
            ]
          },
          "linked_gap_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "mechanism_group_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_term_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_record_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "issue_draft_path": {
            "type": "string"
          },
          "public_deliverables": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "acceptance_checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "what_not_to_infer": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "safety_boundary": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "github_issue_url": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/claim-set.schema.json",
  "title": "Curing Blood Cancer Claim Set",
  "type": "object",
  "required": [
    "claim_set_id",
    "date",
    "disease_program",
    "claim_set_title",
    "blood_cancer_scope",
    "clinical_use_boundary",
    "source_ids",
    "mechanism_group_ids",
    "extraction_record_ids",
    "claims",
    "review"
  ],
  "properties": {
    "claim_set_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "claim_set_title": {
      "type": "string",
      "minLength": 1
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "parent_map_id": {
      "type": "string"
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "taxonomy_class_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism_group_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extraction_record_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "measurement_term_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "claim_text",
          "claim_kind",
          "claim_status",
          "evidence_level",
          "mechanism_group_ids",
          "source_ids",
          "extraction_record_ids",
          "supports",
          "does_not_support",
          "limitations"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "claim_text": {
            "type": "string",
            "minLength": 1
          },
          "claim_kind": {
            "type": "string",
            "enum": [
              "definition",
              "classification",
              "mechanism",
              "intervention-class",
              "biomarker",
              "trial-landscape",
              "regulatory-status",
              "statistics",
              "cure-hypothesis",
              "vaccine-hypothesis",
              "open-question"
            ]
          },
          "claim_status": {
            "type": "string",
            "enum": [
              "fact",
              "derived",
              "hypothesis",
              "open-question",
              "do-not-use-clinically"
            ]
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "source-summary",
              "registry-record",
              "regulatory-record",
              "observational-study",
              "clinical-trial",
              "systematic-review",
              "mechanistic-preclinical",
              "expert-review-needed",
              "hypothesis-only"
            ]
          },
          "mechanism_group_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_record_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_term_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "does_not_support": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

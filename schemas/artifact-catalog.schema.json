{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/artifact-catalog.schema.json",
  "title": "Curing Blood Cancer Artifact Catalog",
  "type": "object",
  "required": [
    "catalog_id",
    "date",
    "title",
    "clinical_use_boundary",
    "generated_from",
    "entries",
    "review"
  ],
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "generated_from": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "title",
          "artifact_class",
          "claim_level",
          "path",
          "metadata_path",
          "source_count",
          "limitation_count"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "artifact_class": {
            "type": "string"
          },
          "claim_level": {
            "type": "string"
          },
          "blood_cancer_scope": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "path": {
            "type": "string"
          },
          "metadata_path": {
            "type": "string"
          },
          "source_count": {
            "type": "integer"
          },
          "limitation_count": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

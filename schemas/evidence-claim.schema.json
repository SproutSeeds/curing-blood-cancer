{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/evidence-claim.schema.json",
  "title": "Curing Blood Cancer Evidence Claim",
  "type": "object",
  "required": [
    "claim_id",
    "claim_text",
    "claim_kind",
    "claim_status",
    "blood_cancer_scope",
    "evidence_level",
    "source_ids",
    "clinical_use_boundary",
    "uncertainty",
    "limitations",
    "review"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "claim_text": {
      "type": "string",
      "minLength": 1
    },
    "claim_kind": {
      "type": "string",
      "enum": [
        "definition",
        "classification",
        "mechanism",
        "intervention-class",
        "biomarker",
        "trial-landscape",
        "regulatory-status",
        "statistics",
        "cure-hypothesis",
        "vaccine-hypothesis",
        "open-question"
      ]
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "fact",
        "derived",
        "hypothesis",
        "open-question",
        "do-not-use-clinically"
      ]
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["subtype"],
        "properties": {
          "subtype": {
            "type": "string"
          },
          "disease_state": {
            "type": "string"
          },
          "population_scope": {
            "type": "string"
          },
          "excluded_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_level": {
      "type": "string",
      "enum": [
        "source-summary",
        "registry-record",
        "regulatory-record",
        "observational-study",
        "clinical-trial",
        "systematic-review",
        "mechanistic-preclinical",
        "expert-review-needed",
        "hypothesis-only"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "supporting_urls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "label": {
            "type": "string"
          },
          "accessed": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      }
    },
    "taxonomy_class_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "trial_query_record_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "targets_or_pathways": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "measurement_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "uncertainty": {
      "type": "object",
      "required": ["summary", "known_unknowns"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "known_unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "possible_failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/measurement-context-audit.schema.json",
  "title": "Curing Blood Cancer Measurement Context Audit",
  "type": "object",
  "required": [
    "audit_id",
    "date",
    "disease_program",
    "title",
    "blood_cancer_scope",
    "clinical_use_boundary",
    "source_ids",
    "linked_claim_ids",
    "extraction_record_ids",
    "measurement_term_ids",
    "required_fields",
    "records",
    "review"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claim_set_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "linked_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extraction_record_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extraction_signal_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "measurement_term_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "github_issue_url": {
      "type": "string",
      "format": "uri"
    },
    "required_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field_id", "field_label", "why_required"],
        "properties": {
          "field_id": {
            "type": "string"
          },
          "field_label": {
            "type": "string"
          },
          "why_required": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "audit_record_id",
          "record_type",
          "record_path",
          "measurement_focus",
          "source_ids",
          "measurement_term_ids",
          "field_status",
          "missing_context_notes",
          "does_not_support"
        ],
        "properties": {
          "audit_record_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "record_type": {
            "type": "string",
            "enum": [
              "claim",
              "extraction-signal"
            ]
          },
          "record_path": {
            "type": "string"
          },
          "linked_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_record_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_signal_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_focus": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_term_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "field_status": {
            "type": "object",
            "required": [
              "assay_method",
              "specimen_source",
              "threshold_or_scoring_method",
              "timepoint_relative_to_therapy",
              "paired_measurements",
              "relapse_or_progression_definition",
              "missing_context_notes"
            ],
            "properties": {
              "assay_method": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "specimen_source": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "threshold_or_scoring_method": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "timepoint_relative_to_therapy": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "paired_measurements": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "relapse_or_progression_definition": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              },
              "missing_context_notes": {
                "type": "string",
                "enum": ["captured", "partially-captured", "missing", "not-applicable"]
              }
            },
            "additionalProperties": false
          },
          "missing_context_notes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "action_needed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_support": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/evidence-gap-register.schema.json",
  "title": "Curing Blood Cancer Evidence Gap Register",
  "type": "object",
  "required": [
    "gap_register_id",
    "date",
    "disease_program",
    "title",
    "blood_cancer_scope",
    "clinical_use_boundary",
    "source_ids",
    "claim_set_ids",
    "gaps",
    "review"
  ],
  "properties": {
    "gap_register_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claim_set_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism_group_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "measurement_term_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extraction_record_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "gap_id",
          "gap_type",
          "priority",
          "gap_statement",
          "why_it_matters",
          "linked_claim_ids",
          "source_ids",
          "public_next_actions",
          "what_would_improve_confidence",
          "what_not_to_infer",
          "limitations"
        ],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "gap_type": {
            "type": "string",
            "enum": [
              "assay-definition",
              "data-availability",
              "evidence-strength",
              "expert-review",
              "mechanism-frequency",
              "measurement-context",
              "source-extraction",
              "trial-landscape",
              "translation-safety"
            ]
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "gap_statement": {
            "type": "string",
            "minLength": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          },
          "linked_claim_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "mechanism_group_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_term_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_record_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "public_next_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "what_would_improve_confidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "what_not_to_infer": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

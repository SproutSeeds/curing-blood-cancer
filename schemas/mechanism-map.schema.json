{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/mechanism-map.schema.json",
  "title": "Curing Blood Cancer Mechanism Map",
  "type": "object",
  "required": [
    "map_id",
    "date",
    "disease_program",
    "cure_wedge",
    "clinical_use_boundary",
    "source_ids",
    "mechanism_groups",
    "next_artifacts",
    "review"
  ],
  "properties": {
    "map_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "cure_wedge": {
      "type": "string"
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "taxonomy_class_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mechanism_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "mechanism_id",
          "label",
          "evidence_level",
          "relapse_role",
          "why_it_matters",
          "what_to_extract",
          "public_measurements",
          "source_ids",
          "limitations"
        ],
        "properties": {
          "mechanism_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "label": {
            "type": "string"
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "source-summary",
              "registry-record",
              "regulatory-record",
              "observational-study",
              "clinical-trial",
              "systematic-review",
              "mechanistic-preclinical",
              "expert-review-needed",
              "hypothesis-only"
            ]
          },
          "relapse_role": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "what_to_extract": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "public_measurements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "next_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "purpose"],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "purpose": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["created", "last_reviewed", "review_status"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/curing-blood-cancer/expert-review-packet.schema.json",
  "title": "Curing Blood Cancer Expert Review Packet",
  "type": "object",
  "required": [
    "review_packet_id",
    "date",
    "disease_program",
    "title",
    "blood_cancer_scope",
    "clinical_use_boundary",
    "review_scope",
    "target_artifacts",
    "claim_set_ids",
    "gap_register_ids",
    "linked_gap_ids",
    "linked_claim_ids",
    "source_ids",
    "measurement_term_ids",
    "extraction_record_ids",
    "review_status_boundary",
    "review_items",
    "completion_gate",
    "interpretation_boundary",
    "review"
  ],
  "properties": {
    "review_packet_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "disease_program": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "blood_cancer_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "clinical_use_boundary": {
      "type": "string",
      "enum": [
        "not-medical-advice",
        "not-diagnostic",
        "not-treatment-recommendation",
        "not-trial-recommendation",
        "research-use-only",
        "requires-clinician-review"
      ]
    },
    "review_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "target_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "path",
          "current_review_status",
          "review_goal"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "current_review_status": {
            "type": "string",
            "enum": [
              "source-checked",
              "expert-review-needed",
              "expert-reviewed"
            ]
          },
          "review_goal": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "claim_set_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "gap_register_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "linked_gap_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "linked_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "measurement_term_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extraction_record_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "review_status_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "review_item_id",
          "review_focus",
          "linked_claim_ids",
          "linked_gap_ids",
          "source_ids",
          "measurement_term_ids",
          "extraction_record_ids",
          "review_questions",
          "required_reviewer_roles",
          "current_public_status",
          "reviewer_action_needed",
          "claim_language_action",
          "safety_boundary"
        ],
        "properties": {
          "review_item_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
          },
          "review_focus": {
            "type": "string",
            "enum": [
              "claim-scope",
              "measurement-assumptions",
              "source-quality",
              "translation-boundary",
              "safety-language",
              "public-readability",
              "unsupported-inference"
            ]
          },
          "linked_claim_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "linked_gap_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "measurement_term_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "extraction_record_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "review_questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_reviewer_roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "current_public_status": {
            "type": "string",
            "enum": [
              "source-checked",
              "expert-review-needed",
              "expert-reviewed"
            ]
          },
          "reviewer_action_needed": {
            "type": "string"
          },
          "claim_language_action": {
            "type": "string",
            "enum": [
              "keep-boundary",
              "weaken-or-clarify",
              "needs-expert-decision"
            ]
          },
          "safety_boundary": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "completion_gate": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "interpretation_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "created",
        "last_reviewed",
        "review_status"
      ],
      "properties": {
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "source-checked",
            "expert-review-needed",
            "expert-reviewed",
            "deprecated"
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
